        <mxCell id="e-flower-redis" value="watch tasks" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=open;dashed=1;strokeColor=#999999;fontColor=#999999;" edge="1" parent="1" source="flower" target="redis">
          <mxGeometry relative="1" as="geometry" />
